# Copy to .env and fill in. NEVER commit your real .env.
# Adopt mode (/adopt, /report) works without any of these set.
# Real mode (/simulate) requires DEVIN_API_KEY, DEVIN_ORG_ID, and GITHUB_TOKEN.

# --- Devin API ---
DEVIN_API_KEY=
# Organization id, prefixed with "org-"
DEVIN_ORG_ID=
# Override the API base if needed (defaults to https://api.devin.ai)
# DEVIN_API_BASE=https://api.devin.ai

# --- GitHub ---
# Personal access token (repo + read access to issues/pulls)
GITHUB_TOKEN=
GITHUB_REPO=RogueTex/superset
# GITHUB_API_BASE=https://api.github.com

# --- Automation tuning ---
# Max ACUs a real-mode Devin session may consume (keeps demo runs cheap)
MAX_ACU_LIMIT=10
# SQLite location (inside the container this defaults to /app/data/autopilot.db)
# DB_PATH=data/autopilot.db
# REQUEST_TIMEOUT=30

# Copy to .env and fill in. Never commit your real .env.
# /runs/import and /summary work without credentials.
# Creating new Devin sessions requires DEVIN_API_KEY, DEVIN_ORG_ID, and GITHUB_TOKEN.

# --- Devin API ---
DEVIN_API_KEY=
# Organization id, prefixed with "org-"
DEVIN_ORG_ID=
# DEVIN_API_BASE=https://api.devin.ai

# --- GitHub ---
# Fine-grained token with issue read/write access and pull request read access.
GITHUB_TOKEN=
GITHUB_REPO=RogueTex/superset
# GITHUB_API_BASE=https://api.github.com

# --- Trigger filtering ---
WEBHOOK_LABEL=devin-remediate
# Optional shared bearer token for public runner endpoints. Set the same value
# as the target repo's RUNNER_SHARED_TOKEN secret.
# RUNNER_SHARED_TOKEN=

# --- Runtime tuning ---
MAX_ACU_LIMIT=10
# DB_PATH=data/devin_issue_runner.db
# REQUEST_TIMEOUT=30
